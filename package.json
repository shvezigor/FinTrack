{
  "name": "resource-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "db:generate": "prisma generate",
    "db:prepare:test": "prisma db push --skip-generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:dashboard": "npm --workspace apps/dashboard run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "format": "prettier --write .",
    "test": "npm run test:unit",
    "test:all": "npm run test:db:up && npm run test:ci",
    "test:ci": "npm run db:generate && npm run db:prepare:test && npm run typecheck && npm run test:unit && npm run build && npm run test:e2e",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d postgres-test",
    "test:e2e": "playwright test",
    "test:unit": "tsx --test packages/shared/src/*.test.ts packages/server/src/**/*.test.ts apps/api/src/**/*.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "latest",
    "prettier": "latest",
    "prisma": "^6.19.3",
    "tsx": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
