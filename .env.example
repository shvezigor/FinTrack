# Core
NODE_ENV=development
TIMEZONE=Europe/Kyiv
APP_BASE_URL=http://localhost:3001
DATABASE_URL=postgresql://resource_manager:resource_manager@localhost:5433/resource_manager?schema=public
PUBLIC_UPLOAD_BASE_URL=http://localhost:3001
UPLOAD_DIR=uploads

# Required for accepting encrypted secrets from Telegram.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_SECRET_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_TELEGRAM_USER_IDS=
ADMIN_CLAIM_SECRET=
ENABLE_TELEGRAM_SECRET_SETUP=false
TELEGRAM_USE_POLLING=false

# Dashboard
DASHBOARD_ADMIN_PASSWORD=change-me
API_INTERNAL_URL=http://localhost:3001

# Optional env-based credentials. These are preferred for production.
MONOBANK_TOKEN=
MONOBANK_ACCOUNT_ID=
MONOBANK_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
